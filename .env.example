# HTTP port used by the media-api container.
PORT=3000

# Host-side Azurite connection string for local development.
# Docker Compose overrides this with the same connection string using `azurite` as the hostname.
AZURE_STORAGE_CONNECTION_STRING=AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;DefaultEndpointsProtocol=http;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;QueueEndpoint=http://127.0.0.1:10001/devstoreaccount1;TableEndpoint=http://127.0.0.1:10002/devstoreaccount1;

# Blob container name for original uploads and derived WebP outputs.
AZURE_BLOB_CONTAINER_NAME=media

# Queue Storage queue name for image optimization jobs.
AZURE_QUEUE_NAME=image-jobs

# Table Storage table name for durable metadata records.
AZURE_TABLE_NAME=mediajobs

# Compose service name + Redis default port.
REDIS_URL=redis://redis:6379

# How long the worker waits before polling again when the queue is empty.
WORKER_POLL_INTERVAL_MS=3000

# Once a worker receives a message, it stays hidden from other workers
# for this many seconds unless the worker deletes it.
QUEUE_VISIBILITY_TIMEOUT_SECONDS=120
