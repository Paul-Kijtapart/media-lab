{
  "name": "media-lab",
  "version": "1.0.0",
  "private": true,
  "description": "Beginner-friendly Docker + Azurite + Redis media processing lab",
  "scripts": {
    "dev:api": "tsx watch src/server.ts",
    "dev:image-worker": "tsx watch src/workers/image-worker.ts",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "start:api": "node dist/server.js",
    "start:image-worker": "node dist/workers/image-worker.js"
  },
  "dependencies": {
    "@azure/data-tables": "^13.3.0",
    "@azure/storage-blob": "^12.26.0",
    "@azure/storage-queue": "^12.25.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "redis": "^4.7.0",
    "sharp": "^0.34.1",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/express": "^5.0.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.0",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript-eslint": "^8.30.1",
    "typescript": "^5.8.3"
  }
}
